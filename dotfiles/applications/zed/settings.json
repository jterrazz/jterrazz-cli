  "outline_panel": {
    "dock": "right"
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right"
  },
  "git_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left",
    "button": true
  },
  "project_panel": {
    "dock": "left"
  },
  "agent_ui_font_size": 15.6,
  "autosave": "on_focus_change",
  "auto_indent_on_paste": true,
  "minimap": {
    "show": "auto"
  },
  "terminal": {
    "font_size": 13.0
  },
  "base_keymap": "VSCode",
  "icon_theme": {
    "mode": "light",
    "light": "Base Charmed Icons",
    "dark": "Base Charmed Icons"
  },
  "tab_size": 4,
  "ui_font_size": 15.4,
  "buffer_font_size": 13,
  "theme": {
    "mode": "light",
    "light": "Polar",
    "dark": "Sequoia Moonlight"
  },
  "auto_install_extensions": {
    "ansible": true,
    "bearded-icon-theme": true,
    "catppuccin": true,
    "catppuccin-blur": true,
    "charmed-icons": true,
    "dockerfile": true,
    "git-firefly": true,
    "graphql": true,
    "html": true,
    "java": true,
    "make": true,
    "nord": true,
    "nvim-nightfox": true,
    "opencode": true,
    "oxc": true,
    "prisma": true,
    "scss": true,
    "serendipity": true,
    "sql": true,
    "swift": true,
    "terraform": true,
    "tokyo-night": true,
    "toml": true,
    "vesper": true,
    "vue": true,
    "xml": true,
    "zig": true
  },
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry",
      "default_mode": "bypassPermissions",
      "default_model": "default",
      "favorite_config_option_values": {
        "mode": ["bypassPermissions"]
      }
    },
    "gemini-custom": {
      "type": "custom",
      "command": "gemini"
    }
  },
  "lsp": {
    "oxlint": {
      "initialization_options": {
        "settings": {
          "configPath": null,
          "run": "onType",
          "disableNestedConfig": false,
          "fixKind": "safe_fix",
          "typeAware": true,
          "unusedDisableDirectives": "deny"
        }
      }
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "configPath": null,
          "run": "onSave"
        }
      }
    }
  },
  "languages": {
    "CSS": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "GraphQL": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "Handlebars": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "HTML": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JavaScript": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        },
        {
          "code_action": "source.fixAll.oxc"
        }
      ]
    },
    "JSX": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
